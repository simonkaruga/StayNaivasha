# Backend — copy to .env for local dev ONLY. Never commit .env.
# All production values live in Railway environment variables.

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/staynaivasha
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace-with-strong-random-secret

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://staynaivasha.co.ke/api/payments/mpesa/callback

AT_API_KEY=
AT_USERNAME=sandbox

CLAUDE_API_KEY=
SENDGRID_API_KEY=
FCM_SERVER_KEY=
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

SENTRY_DSN=

# Frontend (Vite) — prefix with VITE_ to expose to browser
# Generate VAPID key pair once with: npx web-push generate-vapid-keys
# Set VITE_VAPID_PUBLIC_KEY in frontend env, VAPID_PRIVATE_KEY in backend env
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@staynaivasha.co.ke

# Cloudinary — unsigned upload preset for direct browser uploads
VITE_CLOUDINARY_CLOUD=
VITE_CLOUDINARY_PRESET=staynaivasha
